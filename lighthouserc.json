{
	"ci": {
		"collect": {
			"staticDistDir": "./build",
			"numberOfRuns": 1
		},
		"assert": {
			"assertMatrix": [
				{
					"comment": "The 404 page is intentionally noindex, so the SEO/indexability gate does not apply to it.",
					"matchingUrlPattern": ".*/404\\.html$",
					"assertions": {
						"categories:accessibility": ["error", { "minScore": 1 }],
						"categories:performance": ["error", { "minScore": 0.8 }],
						"categories:best-practices": ["error", { "minScore": 0.9 }]
					}
				},
				{
					"comment": "Every indexable page: a11y must be perfect; perf/BP/SEO are hard floors.",
					"matchingUrlPattern": "^(?!.*/404\\.html$).*$",
					"assertions": {
						"categories:accessibility": ["error", { "minScore": 1 }],
						"categories:performance": ["error", { "minScore": 0.8 }],
						"categories:best-practices": ["error", { "minScore": 0.9 }],
						"categories:seo": ["error", { "minScore": 0.9 }]
					}
				}
			]
		}
	}
}
